<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="org.example.controller.StudentController"
            prefWidth="1200" prefHeight="800"
            style="-fx-padding: 10;">

    <top>
        <VBox spacing="10">
            <Label text="Student Management"
                   style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;"/>
            <Separator/>

            <!-- Search Section -->
            <HBox spacing="10" alignment="CENTER_LEFT">
                <Label text="Search Students:"/>
                <TextField fx:id="txtSearch" promptText="Enter student name..." prefWidth="300"/>
                <Button fx:id="btnSearch" text="Search" onAction="#handleSearch"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Button fx:id="btnClear" text="Clear Form" onAction="#handleClearForm" style="-fx-background-color: #95a5a6; -fx-text-fill: white;"/>
            </HBox>
        </VBox>
    </top>

    <center>
        <SplitPane dividerPositions="0.6" orientation="HORIZONTAL">

            <!-- Left: Student Table -->
            <VBox spacing="10">
                <Label text="Students List" style="-fx-font-size: 16px; -fx-font-weight: bold;"/>
                <TableView fx:id="studentTable" VBox.vgrow="ALWAYS">
                    <columns>
                        <TableColumn fx:id="colId" text="ID" prefWidth="50"/>
                        <TableColumn fx:id="colRegNumber" text="Reg Number" prefWidth="120"/>
                        <TableColumn fx:id="colFirstName" text="First Name" prefWidth="120"/>
                        <TableColumn fx:id="colLastName" text="Last Name" prefWidth="120"/>
                        <TableColumn fx:id="colEmail" text="Email" prefWidth="150"/>
                        <TableColumn fx:id="colDepartment" text="Department" prefWidth="120"/>
                        <TableColumn fx:id="colEnrollmentDate" text="Enrollment Date" prefWidth="120"/>
                    </columns>
                </TableView>
            </VBox>

            <!-- Right: Student Form -->
            <VBox spacing="15" style="-fx-padding: 10;">
                <Label text="Student Details" style="-fx-font-size: 16px; -fx-font-weight: bold;"/>

                <GridPane hgap="10" vgap="10">
                    <columnConstraints>
                        <ColumnConstraints prefWidth="100"/>
                        <ColumnConstraints prefWidth="200"/>
                    </columnConstraints>

                    <!-- Hidden ID Field -->
                    <Label text="ID:" GridPane.columnIndex="0" GridPane.rowIndex="0"/>
                    <TextField fx:id="txtId" editable="false" style="-fx-background-color: #ecf0f1;" GridPane.columnIndex="1" GridPane.rowIndex="0"/>

                    <Label text="Reg Number:*" GridPane.columnIndex="0" GridPane.rowIndex="1"/>
                    <TextField fx:id="txtRegistrationNumber" promptText="e.g., CS001" GridPane.columnIndex="1" GridPane.rowIndex="1"/>

                    <Label text="First Name:*" GridPane.columnIndex="0" GridPane.rowIndex="2"/>
                    <TextField fx:id="txtFirstName" promptText="Enter first name" GridPane.columnIndex="1" GridPane.rowIndex="2"/>

                    <Label text="Last Name:*" GridPane.columnIndex="0" GridPane.rowIndex="3"/>
                    <TextField fx:id="txtLastName" promptText="Enter last name" GridPane.columnIndex="1" GridPane.rowIndex="3"/>

                    <Label text="Email:" GridPane.columnIndex="0" GridPane.rowIndex="4"/>
                    <TextField fx:id="txtEmail" promptText="email@example.com" GridPane.columnIndex="1" GridPane.rowIndex="4"/>

                    <Label text="Date of Birth:" GridPane.columnIndex="0" GridPane.rowIndex="5"/>
                    <DatePicker fx:id="dateDateOfBirth" GridPane.columnIndex="1" GridPane.rowIndex="5"/>

                    <Label text="Department:" GridPane.columnIndex="0" GridPane.rowIndex="6"/>
                    <TextField fx:id="txtDepartment" promptText="e.g., Computer Science" GridPane.columnIndex="1" GridPane.rowIndex="6"/>

                    <Label text="Enrollment Date:*" GridPane.columnIndex="0" GridPane.rowIndex="7"/>
                    <DatePicker fx:id="dateEnrollmentDate" GridPane.columnIndex="1" GridPane.rowIndex="7"/>
                </GridPane>

                <!-- Action Buttons -->
                <HBox spacing="10" alignment="CENTER">
                    <Button fx:id="btnAdd" text="Add Student" onAction="#handleAddStudent"
                            style="-fx-background-color: #27ae60; -fx-text-fill: white; -fx-pref-width: 100;"/>
                    <Button fx:id="btnUpdate" text="Update" onAction="#handleUpdateStudent"
                            style="-fx-background-color: #2980b9; -fx-text-fill: white; -fx-pref-width: 100;"/>
                    <Button fx:id="btnDelete" text="Delete" onAction="#handleDeleteStudent"
                            style="-fx-background-color: #e74c3c; -fx-text-fill: white; -fx-pref-width: 100;"/>
                </HBox>

                <VBox spacing="5" style="-fx-padding: 10; -fx-background-color: #f8f9fa; -fx-border-color: #bdc3c7;">
                    <Label text="Instructions:" style="-fx-font-weight: bold;"/>
                    <Label text="• Fields marked with * are required"/>
                    <Label text="• Click on a student in the table to edit or delete"/>
                    <Label text="• Use search to find specific students"/>
                </VBox>
            </VBox>
        </SplitPane>
    </center>
</BorderPane>