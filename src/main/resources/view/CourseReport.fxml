<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<BorderPane xmlns="http://javafx.com/javafx/17.0.17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="org.example.controller.CourseReportController"
            prefWidth="1200" prefHeight="800"
            style="-fx-padding: 15;">

    <top>
        <VBox spacing="15">
            <Label text="Course Reports - Academic Analytics"
                   style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;"/>
            <Separator/>

            <!-- Summary Statistics -->
            <HBox spacing="30" alignment="CENTER">
                <VBox alignment="CENTER" style="-fx-padding: 10; -fx-background-color: #e8f4fd; -fx-border-color: #3498db; -fx-border-radius: 5;">
                    <Label text="Total Courses" style="-fx-font-size: 12px; -fx-text-fill: #2980b9;"/>
                    <Label fx:id="totalCoursesLabel" text="0" style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #2980b9;"/>
                </VBox>
                <VBox alignment="CENTER" style="-fx-padding: 10; -fx-background-color: #e8f6f3; -fx-border-color: #27ae60; -fx-border-radius: 5;">
                    <Label text="Total Enrollments" style="-fx-font-size: 12px; -fx-text-fill: #27ae60;"/>
                    <Label fx:id="totalEnrollmentsLabel" text="0" style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #27ae60;"/>
                </VBox>
                <VBox alignment="CENTER" style="-fx-padding: 10; -fx-background-color: #fef9e7; -fx-border-color: #f39c12; -fx-border-radius: 5;">
                    <Label text="Avg per Course" style="-fx-font-size: 12px; -fx-text-fill: #f39c12;"/>
                    <Label fx:id="averageEnrollmentsLabel" text="0.0" style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #f39c12;"/>
                </VBox>
            </HBox>
        </VBox>
    </top>

    <center>
        <TabPane>
            <!-- Individual Course Report Tab -->
            <Tab text="Individual Course Report">
                <VBox spacing="15" style="-fx-padding: 15;">
                    <!-- Course Selection -->
                    <HBox spacing="10" alignment="CENTER_LEFT">
                        <Label text="Select Course:" style="-fx-font-weight: bold;"/>
                        <ComboBox fx:id="courseComboBox" prefWidth="400"/>
                        <Button text="Generate Report" onAction="#handleGenerateCourseReport"
                                style="-fx-background-color: #3498db; -fx-text-fill: white; -fx-font-weight: bold;"/>
                        <Button text="Export" onAction="#handleExportReport"
                                style="-fx-background-color: #27ae60; -fx-text-fill: white;"/>
                        <Button text="Print" onAction="#handlePrintReport"
                                style="-fx-background-color: #e67e22; -fx-text-fill: white;"/>
                    </HBox>

                    <!-- Report Display -->
                    <Label text="Course Report:" style="-fx-font-weight: bold;"/>
                    <TextArea fx:id="reportTextArea" prefRowCount="20" wrapText="true"
                              style="-fx-font-family: 'Consolas', 'Monaco', monospace; -fx-font-size: 12px;"/>
                </VBox>
            </Tab>

            <!-- All Courses Overview Tab -->
            <Tab text="All Courses Overview">
                <VBox spacing="15" style="-fx-padding: 15;">
                    <HBox spacing="10" alignment="CENTER_LEFT">
                        <Label text="Complete Course Catalog Report" style="-fx-font-weight: bold;"/>
                        <Region HBox.hgrow="ALWAYS"/>
                        <Button text="Refresh Data" onAction="#handleGenerateAllCoursesReport"
                                style="-fx-background-color: #9b59b6; -fx-text-fill: white;"/>
                    </HBox>

                    <TableView fx:id="allCoursesTable" VBox.vgrow="ALWAYS">
                        <columns>
                            <TableColumn fx:id="colCourseCode" text="Course Code" prefWidth="100"/>
                            <TableColumn fx:id="colCourseTitle" text="Course Title" prefWidth="200"/>
                            <TableColumn fx:id="colCredits" text="Credits" prefWidth="80"/>
                            <TableColumn fx:id="colEnrollmentCount" text="Enrollments" prefWidth="100"/>
                            <TableColumn fx:id="colDescription" text="Description" prefWidth="300"/>
                        </columns>
                    </TableView>
                </VBox>
            </Tab>
        </TabPane>
    </center>
</BorderPane>