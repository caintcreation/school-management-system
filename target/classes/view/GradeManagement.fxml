<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<VBox xmlns="http://javafx.com/javafx/11.0.1" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="org.example.controller.GradeController" spacing="20" style="-fx-padding: 20; -fx-background-color: #f5f6fa;">

    <!-- Header Section -->
    <Label text="Grade Management System" style="-fx-font-size: 24; -fx-font-weight: bold; -fx-text-fill: #2c3e50;">
        <padding>
            <Insets bottom="10"/>
        </padding>
    </Label>

    <!-- Input and Actions Section -->
    <HBox spacing="30" alignment="TOP_LEFT">
        <!-- Input Fields -->
        <VBox spacing="15" style="-fx-background-color: white; -fx-padding: 20; -fx-background-radius: 10; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 10, 0, 0, 2);" prefWidth="400">
            <Label text="Grade Information" style="-fx-font-size: 16; -fx-font-weight: bold; -fx-text-fill: #34495e;"/>

            <VBox spacing="8">
                <Label text="Enrollment ID:" style="-fx-font-weight: bold; -fx-text-fill: #2c3e50;"/>
                <TextField fx:id="enrollmentIdField" promptText="Enter Enrollment ID"
                           style="-fx-background-radius: 5; -fx-border-color: #bdc3c7; -fx-border-radius: 5; -fx-padding: 8;"/>
            </VBox>

            <VBox spacing="8">
                <Label text="Grade Value:" style="-fx-font-weight: bold; -fx-text-fill: #2c3e50;"/>
                <TextField fx:id="gradeValueField" promptText="Enter Grade (A, B, C, etc.)"
                           style="-fx-background-radius: 5; -fx-border-color: #bdc3c7; -fx-border-radius: 5; -fx-padding: 8;"/>
            </VBox>

            <VBox spacing="8">
                <Label text="Remarks:" style="-fx-font-weight: bold; -fx-text-fill: #2c3e50;"/>
                <TextArea fx:id="remarksArea" promptText="Enter remarks" prefRowCount="3"
                          style="-fx-background-radius: 5; -fx-border-color: #bdc3c7; -fx-border-radius: 5; -fx-padding: 8;"/>
            </VBox>
        </VBox>

        <!-- Action Buttons -->
        <VBox spacing="12" alignment="CENTER" style="-fx-padding: 20 0 0 0;">
            <Button text="Add Grade" onAction="#handleAddGrade" prefWidth="140" prefHeight="35"
                    style="-fx-background-color: #27ae60; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 5; -fx-cursor: hand;"/>
            <Button text="Update Grade" onAction="#handleUpdateGrade" prefWidth="140" prefHeight="35"
                    style="-fx-background-color: #3498db; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 5; -fx-cursor: hand;"/>
            <Button text="Delete Grade" onAction="#handleDeleteGrade" prefWidth="140" prefHeight="35"
                    style="-fx-background-color: #e74c3c; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 5; -fx-cursor: hand;"/>
            <Button text="Generate Report" onAction="#handleGenerateReport" prefWidth="140" prefHeight="35"
                    style="-fx-background-color: #9b59b6; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 5; -fx-cursor: hand;"/>
        </VBox>
    </HBox>

    <!-- Search Section -->
    <VBox spacing="12" style="-fx-background-color: white; -fx-padding: 15; -fx-background-radius: 10; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 10, 0, 0, 2);">
        <Label text="Search Grades" style="-fx-font-size: 16; -fx-font-weight: bold; -fx-text-fill: #34495e;"/>
        <HBox spacing="10" alignment="CENTER_LEFT">
            <ComboBox fx:id="searchTypeComboBox" prefWidth="180" prefHeight="35"
                      style="-fx-background-radius: 5; -fx-border-color: #bdc3c7; -fx-border-radius: 5;"/>
            <TextField fx:id="searchField" promptText="Enter search term" prefWidth="250" prefHeight="35"
                       style="-fx-background-radius: 5; -fx-border-color: #bdc3c7; -fx-border-radius: 5; -fx-padding: 8;"/>
            <Button text="Search" onAction="#handleSearch" prefWidth="80" prefHeight="35"
                    style="-fx-background-color: #2c3e50; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 5; -fx-cursor: hand;"/>
            <Button text="Clear" onAction="#handleClearSearch" prefWidth="80" prefHeight="35"
                    style="-fx-background-color: #95a5a6; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 5; -fx-cursor: hand;"/>
        </HBox>
    </VBox>

    <!-- Table Section -->
    <VBox spacing="10" VBox.vgrow="ALWAYS">
        <Label text="Grade Records" style="-fx-font-size: 16; -fx-font-weight: bold; -fx-text-fill: #34495e;"/>
        <TableView fx:id="gradeTable" VBox.vgrow="ALWAYS"
                   style="-fx-background-radius: 10; -fx-border-radius: 10; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 10, 0, 0, 2);">
            <columns>
                <TableColumn fx:id="colId" text="ID" prefWidth="60"
                             style="-fx-alignment: CENTER; -fx-font-weight: bold;"/>
                <TableColumn fx:id="colStudentName" text="Student Name" prefWidth="180"
                             style="-fx-font-weight: bold;"/>
                <TableColumn fx:id="colCourseCode" text="Course Code" prefWidth="120"
                             style="-fx-alignment: CENTER; -fx-font-weight: bold;"/>
                <TableColumn fx:id="colGradeValue" text="Grade" prefWidth="80"
                             style="-fx-alignment: CENTER; -fx-font-weight: bold;"/>
                <TableColumn fx:id="colGradeDate" text="Date" prefWidth="130"
                             style="-fx-alignment: CENTER; -fx-font-weight: bold;"/>
                <TableColumn fx:id="colRemarks" text="Remarks" prefWidth="250"
                             style="-fx-font-weight: bold;"/>
            </columns>
            <columnResizePolicy>
                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
            </columnResizePolicy>
        </TableView>
    </VBox>

</VBox>